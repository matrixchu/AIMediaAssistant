# ============================================================================
# AI Media Assistant — environment configuration
# Copy to `.env` and adjust. All values have safe defaults for local/offline use.
# ============================================================================

# ---- App ----
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ---- Database (MySQL) ----
# Point these at your MySQL server to use it as the real database. If DB_HOST is
# left EMPTY, the app falls back to a local SQLite file (data/app.db).
# Example for a MySQL server on your LAN / NAS:
#   DB_HOST=192.168.50.10
#   DB_PORT=3306
#   DB_NAME=ai_media_assistant
#   DB_USER=media
#   DB_PASSWORD=your-password
DB_HOST=192.168.50.98
DB_PORT=3306
DB_NAME=ai_media_assistant
DB_USER=media
DB_PASSWORD=Media@1985

# ---- LLM provider ----
# Provider: "ollama" (default, local), "openai" (OpenAI-compatible endpoint),
# or "none" to disable the LLM and use the deterministic rule-based agent path.
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:8b
LLM_TEMPERATURE=0.2
OLLAMA_BASE_URL=http://localhost:11434
# Used only when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Embeddings (RAG) ----
# "ollama" uses OLLAMA_BASE_URL + EMBED_MODEL; "fallback" uses a deterministic
# hashing embedding that needs no model (great for tests / offline).
EMBED_PROVIDER=fallback
EMBED_MODEL=nomic-embed-text
VECTOR_STORE_DIR=data/chroma

# ---- qBittorrent ----
# This can be a REMOTE qBittorrent running on your NAS — just point QB_HOST at
# its Web UI address. Torrents are uploaded via the API and downloaded straight
# to the NAS at DOWNLOAD_SAVE_PATH (a path on the NAS filesystem).
#   QB_HOST=http://192.168.50.10:8080      # your NAS IP + qB Web UI port
#   QB_USERNAME=admin
#   QB_PASSWORD=your-password
#   DOWNLOAD_SAVE_PATH=/volume1/media/downloads
QB_HOST=http://qb.cassiecloud.top:9001
QB_USERNAME=admin
QB_PASSWORD=Mg0632009
# Set QB_MOCK=true to simulate downloads; set false to drive the real (NAS) qB.
QB_MOCK=true
QB_CATEGORY=ai-media
DOWNLOAD_SAVE_PATH=/downloads

# ---- PT site ----
# Backend: "mock" (offline sample catalog), "rss" (your member tracker's
# personal RSS feed — best for a single private site you joined), "torznab"
# (Jackett/Prowlarr), or "json" (custom JSON API).
PT_BACKEND=rss
# Legacy switch: PT_MOCK=true forces the mock backend.
PT_MOCK=true
PT_SITE_NAME=demo-pt
PT_MIN_SEEDERS=1

# --- PT via your member site's RSS feed (PT_BACKEND=rss) ---
# Paste the personal RSS URL from your PT site (Subscriptions / RSS page). It
# contains your passkey, so keep this file private (.env is git-ignored).
# If the feed supports searching, include a {keyword} placeholder; otherwise the
# newest items are fetched and filtered locally by your query.
#   Searchable:  PT_RSS_URL=https://pt.example/torrentrss.php?passkey=XXXX&search={keyword}
#   Latest-only: PT_RSS_URL=https://pt.example/torrentrss.php?passkey=XXXX&cat=401
PT_RSS_URL=https://audiences.me/torrentrss.php?rows=10&cat401=1&cat402=1&cat403=1&cat406=1&cat408=1&cat404=1&cat405=1&cat407=1&cat410=1&cat412=1&cat409=1&sta10=1&sta5=1&sta1=1&icat=1&isize=1&itags=1&torrent_type=1&linktype=dl&rsskey=e3700abe4b8c4bed2c93e67f68ef0484

# --- PT via Torznab (PT_BACKEND=torznab; Jackett/Prowlarr) ---
#   Jackett:  PT_BASE_URL=http://127.0.0.1:9117/api/v2.0/indexers/all/results/torznab/api
#   Prowlarr: PT_BASE_URL=http://127.0.0.1:9696/<indexerId>/api
#
# --- PT web-page fallback search (optional) ---
# If RSS/local cache has no hit, SearchService can simulate a normal website
# search page request by using PT_BASE_URL + PT_COOKIE.
#
# Example (Audiences-like):
#   PT_BASE_URL=https://audiences.me/torrents.php
#   PT_COOKIE=uid=...; pass=...; PHPSESSID=...
#
# Optional: tracker-specific query mapping for web fallback search.
# 1) Simple parameter mapping mode (when no PT_WEB_QUERY_TEMPLATE is set):
#   PT_WEB_KEYWORD_PARAM=search
#   PT_WEB_CATEGORY_PARAM=cat
#   PT_WEB_CATEGORY_PARAM_MAP={"电影":"cat401","剧集":"cat402","综艺":"cat403","纪录片":"cat406","音乐":"cat408"}
#   PT_WEB_RESOLUTION_PARAM=standard
#   PT_WEB_QUALITY_PARAM=source
#   PT_WEB_MIN_SEEDERS_PARAM=seeders
#   PT_WEB_PAGE_PARAM=page
#
# 2) Full URL template mode (recommended for highly customized PT sites):
#   PT_WEB_QUERY_TEMPLATE=https://pt.example/torrents.php?search={keyword}&cat={category}&standard={resolution}&source={quality}&spstate={min_seeders}&page={page}
# Supported placeholders: {keyword} {category} {resolution} {quality}
# {min_seeders} {min_size_gb} {max_size_gb} {page}
PT_BASE_URL=
PT_API_KEY=
PT_COOKIE=
# Max number of web result pages to crawl when RSS/local cache misses.
PT_WEB_MAX_PAGES=5
PT_WEB_QUERY_TEMPLATE=
PT_WEB_KEYWORD_PARAM=search
PT_WEB_CATEGORY_PARAM=
PT_WEB_CATEGORY_PARAM_MAP=
PT_WEB_RESOLUTION_PARAM=
PT_WEB_QUALITY_PARAM=
PT_WEB_MIN_SEEDERS_PARAM=
PT_WEB_MIN_SIZE_GB_PARAM=
PT_WEB_MAX_SIZE_GB_PARAM=
PT_WEB_PAGE_PARAM=page

# ---- Agent safety / guardrails ----
# Require an explicit confirmation flag before download actions are executed.
AGENT_REQUIRE_DOWNLOAD_CONFIRM=false
# Max tool-call iterations per agent run (prevents runaway loops).
AGENT_MAX_ITERATIONS=12
